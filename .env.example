# Project Settings → API → Project URL (https://xxxx.supabase.co)
# postgres:// 또는 pooler 주소를 넣으면 안 됩니다.
SUPABASE_URL=https://xxxx.supabase.co

# Project Settings → API → service_role (secret). 로컬/Vercel에만 보관.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase → Settings → Data API → Exposed schemas 에 stock, basic 이 있어야 함 (없으면 PGRST106)
SUPABASE_SCHEMA_STOCK=stock
SUPABASE_SCHEMA_BASIC=basic
