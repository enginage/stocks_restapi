SUPABASE_URL=https://xxxx.supabase.co
# 서버 전용: RLS 우회. Vercel 환경 변수에만 저장하고 커밋하지 말 것.
SUPABASE_SERVICE_ROLE_KEY=

# 선택: anon 만 쓸 경우 (RLS 정책이 읽기 허용이어야 함)
# SUPABASE_ANON_KEY=

# DB 스키마 (Supabase에 stock / basic 이 API로 노출되어 있어야 함)
SUPABASE_SCHEMA_STOCK=stock
SUPABASE_SCHEMA_BASIC=basic

# CORS (쉼표 구분). 비우면 *
# ALLOWED_ORIGINS=https://early-retire-lab.vercel.app,http://localhost:5173
